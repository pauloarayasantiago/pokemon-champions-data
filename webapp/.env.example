# Data root — points at the project root where pokemon_champions.csv lives.
# Local dev: ../ (this file is in webapp/)
# Vercel: leave unset — outputFileTracingRoot traces CSVs from project root.
POKEMON_DATA_ROOT=../

# Supabase (vector store — replaces LanceDB).
# URL + publishable key are safe in client bundles. Secret key is server-only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# LLM provider keys. At least one must be set for /api/team to work.
# Free-tier models (no payment required):
OPENROUTER_API_KEY=sk-or-v1-...
GOOGLE_GENAI_API_KEY=...
GROQ_API_KEY=gsk_...

# Paid models (Anthropic):
ANTHROPIC_API_KEY=sk-ant-...
